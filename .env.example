# Supabase project credentials
# Create a project at https://supabase.com, then copy these from Project Settings → API.
# Use the new publishable key (sb_publishable_...), not the legacy anon key.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
